{
  "datasets": [
    {
      "name": "0ca96e81",
      "displayName": "route revenue",
      "queryLines": [
        "SELECT\n",
        "  T.pickup_zip,\n",
        "  T.dropoff_zip,\n",
        "  T.route as `Route`,\n",
        "  T.frequency as `Number Trips`,\n",
        "  T.total_fare as `Total Revenue`\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      pickup_zip,\n",
        "      dropoff_zip,\n",
        "      concat(pickup_zip, '-', dropoff_zip) AS route,\n",
        "      count(*) as frequency,\n",
        "      SUM(fare_amount) as total_fare\n",
        "    FROM\n",
        "      `samples`.`nyctaxi`.`trips`\n",
        "    GROUP BY\n",
        "       1,2,3\n",
        "  ) T\n",
        "ORDER BY\n",
        "  1 ASC"
      ]
    },
    {
      "name": "3f5450e6",
      "displayName": "trips",
      "queryLines": [
        "SELECT\n",
        "  T.tpep_pickup_datetime,\n",
        "  T.tpep_dropoff_datetime,\n",
        "  T.fare_amount,\n",
        "  T.pickup_zip,\n",
        "  T.dropoff_zip,\n",
        "  T.trip_distance,\n",
        "  T.weekday,\n",
        "  CASE\n",
        "    WHEN T.weekday = 1 THEN 'Sunday'\n",
        "    WHEN T.weekday = 2 THEN 'Monday'\n",
        "    WHEN T.weekday = 3 THEN 'Tuesday'\n",
        "    WHEN T.weekday = 4 THEN 'Wednesday'\n",
        "    WHEN T.weekday = 5 THEN 'Thursday'\n",
        "    WHEN T.weekday = 6 THEN 'Friday'\n",
        "    WHEN T.weekday = 7 THEN 'Saturday'\n",
        "    ELSE 'N/A'\n",
        "  END AS day_of_week\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      dayofweek(tpep_pickup_datetime) as weekday,\n",
        "      *\n",
        "    FROM\n",
        "      `samples`.`nyctaxi`.`trips`\n",
        "    WHERE\n",
        "      trip_distance > 0\n",
        "      AND trip_distance < 10\n",
        "      AND fare_amount > 0\n",
        "      AND fare_amount < 50\n",
        "  ) T\n",
        "ORDER BY\n",
        "  T.weekday  "
      ]
    },
    {
      "name": "demand_heatmap",
      "displayName": "Demand Heatmap",
      "queryLines": [
        "SELECT\n",
        "  HOUR(tpep_pickup_datetime) AS pickup_hour,\n",
        "  CASE DAYOFWEEK(tpep_pickup_datetime)\n",
        "    WHEN 1 THEN 'Sun'\n",
        "    WHEN 2 THEN 'Mon'\n",
        "    WHEN 3 THEN 'Tue'\n",
        "    WHEN 4 THEN 'Wed'\n",
        "    WHEN 5 THEN 'Thu'\n",
        "    WHEN 6 THEN 'Fri'\n",
        "    WHEN 7 THEN 'Sat'\n",
        "  END AS day_of_week,\n",
        "  DAYOFWEEK(tpep_pickup_datetime) AS day_num,\n",
        "  COUNT(*) AS ride_count,\n",
        "  AVG(fare_amount) AS avg_fare,\n",
        "  AVG(trip_distance) AS avg_distance\n",
        "FROM\n",
        "  samples.nyctaxi.trips\n",
        "WHERE\n",
        "  trip_distance > 0\n",
        "  AND fare_amount > 0\n",
        "GROUP BY\n",
        "  1,\n",
        "  2,\n",
        "  3\n",
        "ORDER BY\n",
        "  day_num,\n",
        "  pickup_hour"
      ]
    },
    {
      "name": "taxi_insights",
      "displayName": "Taxi Trip Insights",
      "config": {
        "source": "SELECT\n  tpep_pickup_datetime,\n  tpep_dropoff_datetime,\n  trip_distance,\n  fare_amount,\n  pickup_zip,\n  dropoff_zip,\n  HOUR(tpep_pickup_datetime) AS pickup_hour,\n  DAYOFWEEK(tpep_pickup_datetime) AS weekday_num,\n  (UNIX_TIMESTAMP(tpep_dropoff_datetime) - UNIX_TIMESTAMP(tpep_pickup_datetime)) / 60.0 AS trip_duration_min\nFROM samples.nyctaxi.trips WHERE trip_distance > 0 AND fare_amount > 0\n",
        "measures": [
          {
            "name": "trip_count",
            "expr": "COUNT(*)",
            "displayName": "Total Trips"
          },
          {
            "name": "total_revenue",
            "expr": "SUM(fare_amount)",
            "displayName": "Total Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            }
          },
          {
            "name": "avg_fare",
            "expr": "AVG(fare_amount)",
            "displayName": "Avg Fare",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "avg_distance",
            "expr": "AVG(trip_distance)",
            "displayName": "Avg Distance",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "avg_duration_min",
            "expr": "AVG(trip_duration_min)",
            "displayName": "Avg Duration (min)",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "fare_per_mile",
            "expr": "MEASURE(total_revenue) / SUM(trip_distance)",
            "displayName": "Revenue per Mile",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "avg_speed_mph",
            "expr": "SUM(trip_distance) / (SUM(trip_duration_min) / 60.0)",
            "displayName": "Avg Speed (mph)",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          }
        ],
        "filter": "trip_duration_min > 0 AND trip_duration_min < 180",
        "version": 1.1,
        "dimensions": [
          {
            "name": "pickup_hour",
            "expr": "pickup_hour",
            "displayName": "Pickup Hour",
            "comment": "Hour of day when trip started (0-23)"
          },
          {
            "name": "day_of_week",
            "expr": "CASE\n  WHEN weekday_num = 1 THEN 'Sun'\n  WHEN weekday_num = 2 THEN 'Mon'\n  WHEN weekday_num = 3 THEN 'Tue'\n  WHEN weekday_num = 4 THEN 'Wed'\n  WHEN weekday_num = 5 THEN 'Thu'\n  WHEN weekday_num = 6 THEN 'Fri'\n  WHEN weekday_num = 7 THEN 'Sat'\nEND",
            "displayName": "Day of Week"
          },
          {
            "name": "weekday_num",
            "expr": "weekday_num",
            "displayName": "Weekday Number"
          },
          {
            "name": "distance_bucket",
            "expr": "CASE\n  WHEN trip_distance < 1 THEN '< 1 mi'\n  WHEN trip_distance < 2 THEN '1-2 mi'\n  WHEN trip_distance < 3 THEN '2-3 mi'\n  WHEN trip_distance < 5 THEN '3-5 mi'\n  WHEN trip_distance < 10 THEN '5-10 mi'\n  ELSE '10+ mi'\nEND",
            "displayName": "Distance Category"
          },
          {
            "name": "pickup_zip",
            "expr": "pickup_zip",
            "displayName": "Pickup Zip"
          },
          {
            "name": "dropoff_zip",
            "expr": "dropoff_zip",
            "displayName": "Dropoff Zip"
          },
          {
            "name": "pickup_month",
            "expr": "DATE_TRUNC('MONTH', tpep_pickup_datetime)",
            "displayName": "Pickup Month"
          },
          {
            "name": "duration_bucket",
            "expr": "CASE\n  WHEN trip_duration_min < 5 THEN '< 5 min'\n  WHEN trip_duration_min < 10 THEN '5-10 min'\n  WHEN trip_duration_min < 15 THEN '10-15 min'\n  WHEN trip_duration_min < 20 THEN '15-20 min'\n  WHEN trip_duration_min < 30 THEN '20-30 min'\n  ELSE '30+ min'\nEND",
            "displayName": "Duration Category"
          }
        ]
      }
    }
  ],
